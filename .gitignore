# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.pytest_cache/

# Virtual environments
venv/
.env/
.env.*
.venv/

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# Data outputs (generated)
output/
summary/
logs/

# If you later split these further:
# alphalens_pipeline/output/
# factors_testing/output/

# Cached / intermediate data
cache/
*.parquet

# Optional: if parquet is only used for cached market data
# and NEVER raw data storage, keep it ignored:
*.pq

# Archives / large artifacts
*.zip
*.tar
*.tar.gz
*.7z

# Jupyter (if you use notebooks later)
.ipynb_checkpoints/

# Logs (extra safety)
*.log

# Local config overrides (optional)
config.local.json

# Factor testing specific (optional but recommended)
failed_factors.txt
run_all_factors.log

# Large model / data dumps (future-proofing)
*.h5
*.pkl
*.joblib

# Suggested, if project becomes research-heavy
results/
reports/
backtests/

# factors list
factors_testing/*.txt